{
  "name": "okf-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Claude Code skill for converting a project's docs into the OKF (Open Knowledge Format) bundle format.",
  "license": "MIT",
  "author": "Acatl Pacheco",
  "repository": {
    "type": "git",
    "url": "https://github.com/acatl/okf-docs.git"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "spell": "cspell --no-progress --gitignore \"**/*.md\"",
    "sync:check": "scripts/sync-skill-resources.sh check",
    "skills:check": "scripts/check-skill-frontmatter.sh",
    "check": "npm run lint:md && npm run spell && npm run sync:check && npm run skills:check",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "cspell": "^8.17.5",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.16.0"
  }
}
