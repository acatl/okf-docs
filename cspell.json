{
  "version": "0.2",
  "language": "en",
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["project-words", "softwareTerms", "filetypes", "node", "bash"],
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "package-lock.json",
    "project-words.txt"
  ],
  "ignoreRegExpList": [
    "/```[\\s\\S]*?```/",
    "/`[^`]*`/",
    "/\\]\\([^)]*\\)/",
    "/https?:\\/\\/[^\\s)]+/"
  ],
  "allowCompoundWords": true
}
